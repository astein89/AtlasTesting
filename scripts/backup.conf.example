# Copy to backup.conf next to sqlite-dropbox-backup.sh, or set BACKUP_CONF to this file's path.
# shellcheck disable=SC2034

# Absolute path to the live SQLite database (must match the running app, e.g. DB_PATH / default dc-automation.db).
DB_PATH="/opt/dc-automation/dc-automation.db"

# Local staging only: snapshots are uploaded to Dropbox then old local dirs are removed (except policy below).
STAGING_ROOT="/var/lib/dc-automation-backup"

# rclone remote and folder prefix (no trailing slash). Configure with: rclone config
# Example: Dropbox app folder or a dedicated backup path.
RCLONE_REMOTE="dropbox:Backups/dc-automation/sqlite"

# Filename inside each snapshot directory.
BACKUP_BASENAME="dc-automation.db"

# Remote retention: keep the newest N timestamped snapshots under ${RCLONE_REMOTE}/snapshots/
KEEP_LAST=24

# Optional: also delete remote snapshots whose YYYYMMDD date is older than this many days (0 = disable).
# If both KEEP_LAST and MAX_AGE_DAYS are set, more than N snapshots may be removed when age matches.
MAX_AGE_DAYS=0

# Logs
LOG_FILE="${STAGING_ROOT}/logs/backup.log"
LOG_RCLONE="${STAGING_ROOT}/logs/rclone.log"

# Metadata only (not a copy of the DB): last PRAGMA data_version or sha256 for skip-if-unchanged.
STATE_FILE="${STAGING_ROOT}/state/last_data_version"

# Single-instance lock (flock).
LOCK_FILE="${STAGING_ROOT}/run/backup.lock"

# Failure alerts (optional; leave empty to disable)
DISCORD_WEBHOOK=""
MAIL_TO=""

# rclone resilience / tuning (space-separated flags; quoted as one word per deploy)
# Optional: add --bwlimit 1M to limit bandwidth; use a crypt remote for encryption (see rclone crypt).
RCLONE_OPTS="--retries 5 --low-level-retries 10 --timeout 2m"

# After .backup, run PRAGMA integrity_check (1=yes, 0=no)
RUN_INTEGRITY_CHECK=1
