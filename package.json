{
  "name": "dc-automation",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/write-build-version.mjs && concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "cross-env NODE_OPTIONS=--no-deprecation tsx watch server/index.ts",
    "build": "node scripts/write-build-version.mjs && npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "preview": "vite preview",
    "start": "NODE_ENV=production node dist/server/index.js",
    "db:seed": "tsx server/db/seed.ts",
    "db:migrate": "tsx scripts/migrate-sqlite-to-pg.ts",
    "migrate:uploads-testing": "tsx server/scripts/migrate-root-uploads-to-testing.ts",
    "ctl": "bash scripts/ctl.sh"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.3.2",
    "@vavt/rt-extension": "^4.0.0",
    "axios": "^1.6.2",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.5",
    "cron-parser": "^5.5.0",
    "cronstrue": "^3.14.0",
    "date-fns": "^2.30.0",
    "emojilib": "^2.4.0",
    "express": "^4.18.2",
    "html2canvas": "^1.4.1",
    "imask": "^7.6.1",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "markdown-it-attrs": "^4.3.1",
    "md-editor-rt": "^6.4.2",
    "mermaid": "^11.14.0",
    "multer": "^2.1.0",
    "node-emoji": "^2.2.0",
    "papaparse": "^5.4.1",
    "pg": "^8.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.2",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.21.1",
    "remark-breaks": "^4.0.0",
    "remark-emoji": "^5.0.2",
    "remark-gfm": "^4.0.1",
    "unist-util-visit": "^5.1.0",
    "uuid": "^14.0.0",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "overrides": {
    "langium": "4.2.1",
    "lodash-es": "4.18.1",
    "lodash": "4.18.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.10.5",
    "@types/papaparse": "^5.3.14",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^6.4.2"
  }
}
