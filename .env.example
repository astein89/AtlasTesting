# Copy to .env and adjust. Never commit real secrets.

# JWT signing secret for API auth (required in production)
JWT_SECRET=change-me

# SQLite (default when DATABASE_URL is unset)
# DB_PATH=dc-automation.db

# PostgreSQL — when set, the app uses PostgreSQL and ignores SQLite for the server DB
# DATABASE_URL=postgresql://user:password@127.0.0.1:5432/dc-automation
